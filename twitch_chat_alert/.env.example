# Twitch Chat Alert Configuration

# Your Twitch channel to monitor (lowercase)
TWITCH_CHANNEL=your_channel_name

# Your Client Secret from https://dev.twitch.tv/
# 1. Go to https://dev.twitch.tv/
# 2. Create Application > Register Your Application
# 3. Enter your application name
# 4. Set OAuth redirect URI to http://localhost:3000
# 5. Set Category to "Application Integration"
# 6. Once created, go to Applications on the left > select Manage
# 7. Under Client ID section, generate a new Client Secret
# 8. Copy the Client Secret and paste it below
TWITCH_ACCESS_TOKEN=your_client_secret_here

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
