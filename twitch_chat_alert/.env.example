# Twitch Chat Alert Configuration

# Your Twitch channel to monitor (lowercase)
TWITCH_CHANNEL=your_channel_name

# User access token from Twitch's official OAuth flow
# Create a Twitch app and authorize it with the chat:read scope:
# https://dev.twitch.tv/docs/authentication/getting-tokens-oauth/
# Store only the raw token value here, without the oauth: prefix.
TWITCH_ACCESS_TOKEN=your_twitch_access_token_here

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
