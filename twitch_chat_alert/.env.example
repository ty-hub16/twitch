# Twitch Chat Alert Configuration

# Your Twitch channel to monitor (lowercase)
TWITCH_CHANNEL=your_channel_name

# User access token from OAuth implicit grant flow
# Step 1: Get your Client ID from dev.twitch.tv
#   - Go to https://dev.twitch.tv/ and create an application
#   - Set OAuth redirect URI to http://localhost:3000
#   - Copy your Client ID from the app settings
# Step 2: Use your Client ID to get an access token
#   Template URL (replace YOUR_CLIENT_ID with your actual Client ID):
#     https://id.twitch.tv/oauth2/authorize?response_type=token&client_id=YOUR_CLIENT_ID&redirect_uri=http://localhost:3000&scope=chat%3Aread+chat%3Aedit
#   Example (if your Client ID is exampleclientid123456789abcdef):
#     https://id.twitch.tv/oauth2/authorize?response_type=token&client_id=exampleclientid123456789abcdef&redirect_uri=http://localhost:3000&scope=chat%3Aread+chat%3Aedit
#   - Paste your URL (with YOUR_CLIENT_ID replaced) in your browser and click Authorize
#   - You may see an error page, but the token is in the URL
#   - Look at the address bar. It will contain something like:
#     http://localhost:3000/#access_token=exampletoken123456789abcdef&scope=chat%3Aread+chat%3Aedit&token_type=bearer
#   - Copy the token (the long string after access_token= and before &scope) <exampletoken123456789abcdef>
TWITCH_ACCESS_TOKEN=your_user_access_token_here

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
